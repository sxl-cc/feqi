{
  "name": "feqi",
  "version": "0.1.0",
  "description": "A tiny TypeScript request library built as a lightweight wrapper around the Fetch API.",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "bump": "bumpp --execute=\"pnpm i\" --no-push",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepublish": "pnpm build"
  },
  "keywords": [
    "fetch",
    "request",
    "http",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sxl-cc/feqi.git"
  },
  "bugs": {
    "url": "https://github.com/sxl-cc/feqi/issues"
  },
  "homepage": "https://github.com/sxl-cc/feqi#readme",
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "bumpp": "^11.1.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "ultracite": "7.7.0",
    "vitest": "^4.1.6"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  }
}
